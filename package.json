{
  "name": "controle-entregas-tarefas",
  "version": "1.1.0",
  "description": "Sistema de Controle de Entregas e Tarefas Operacionais com painel, API, regras de prazo, LGPD e documentacao de producao.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "check": "node --check server.js && node --test --test-concurrency=1 tests/*.test.js",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "screenshots": "node scripts/generate-screenshots.js",
    "hash:password": "node scripts/hash-password.js",
    "db:migrate": "node scripts/migrate-postgres.js",
    "backup": "node scripts/backup-json.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  }
}
